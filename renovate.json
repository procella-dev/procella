{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": ["at any time"],
  "prConcurrentLimit": 5,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "packageRules": [
    {
      "description": "tygo go.mod owned by self-hosted Renovate (typegen postUpgradeTasks — see .github/renovate-global.js)",
      "matchFileNames": ["packages/types/tygo/**"],
      "enabled": false
    },
    {
      "matchPackageNames": ["astro", "@astrojs/starlight", "zod"],
      "groupName": "astro + starlight + zod"
    },
    {
      "matchPackageNames": ["vite", "@vitejs/plugin-react"],
      "groupName": "vite + plugin-react"
    },
    {
      "matchPackageNames": ["/^oven(-sh)?\\/bun$/"],
      "groupName": "bun"
    },
    {
      "matchPackageNames": ["@trpc/server", "@trpc/client", "@trpc/react-query"],
      "groupName": "trpc"
    }
  ]
}
