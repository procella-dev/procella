{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "bun run typecheck && bun run --cwd apps/ui build && bun build apps/server/src/vercel.ts --target=node --outfile=api/index.mjs --format=esm",
	"installCommand": "bun install --frozen-lockfile",
	"framework": null,
	"outputDirectory": "apps/ui/dist",
	"functions": {
		"api/index.mjs": {
			"maxDuration": 60
		}
	},
	"rewrites": [
		{ "source": "/api/:path(.*)", "destination": "/api/index" },
		{ "source": "/trpc/:path(.*)", "destination": "/api/index" },
		{ "source": "/healthz", "destination": "/api/index" },
		{ "source": "/cron/:path(.*)", "destination": "/api/index" }
	]
}
